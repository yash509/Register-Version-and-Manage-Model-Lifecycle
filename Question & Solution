Step 5: Create the new python script named "mlflow_model_registry.py" for doing the tasks mentioned in comments form in the script below

import mlflow
from mlflow import MlflowClient

mlflow.set_tracking_uri("http://localhost:5000")
client = MlflowClient()

model_name = "fraud-detector"

baseline_run_id = "05f7f7eb3d344d82ab326d23a1fb8019"
improved_run_id = "fe7d5528a74547b7a3a006bf99550c8e"

# Step 1: Create the registered model
try:
    client.create_registered_model(model_name)
    print("Registered model created:", model_name)
except Exception as e:
    print("Model may already exist:", e)

# Step 2: Register baseline run (Version 1)
baseline_model_version = client.create_model_version(
    name=model_name,
    source=f"/root/code/mlflow-artifacts/1/{baseline_run_id}/artifacts/model",
    run_id=baseline_run_id
)

# Step 3: Register improved run (Version 2)
improved_model_version = client.create_model_version(
    name=model_name,
    source=f"/root/code/mlflow-artifacts/1/{improved_run_id}/artifacts/model",
    run_id=improved_run_id
)

# Step 4: Add description
client.update_registered_model(
    name=model_name,
    description="Fraud detection model for xFusionCorp transactions"
)

# Step 5: Assign aliases
client.set_registered_model_alias(model_name, "challenger", baseline_model_version.version)
client.set_registered_model_alias(model_name, "champion", improved_model_version.version)

print("Baseline registered as challenger (v1)")
print("Improved registered as champion (v2)")



